{
  "id": "overlay-road-conditions",
  "version": "1.0.0",
  "domains": ["map-overlay"],
  "quality": "community-verified",
  "frontend": {
    "layerSelector": {
      "group": "map-details",
      "labelKey": "trafficIncidents",
      "icon": "warning"
    },
    "overlay": {
      "minZoom": 5,
      "source": {
        "kind": "geojson-bbox",
        "route": "/observations",
        "bboxParam": "bbox",
        "extraParams": { "domain": "roads" }
      },
      "layers": [
        {
          "id": "points",
          "type": "circle",
          "interactive": true,
          "paint": {
            "circle-radius": ["interpolate", ["linear"], ["zoom"], 5, 4, 12, 8],
            "circle-color": [
              "match",
              ["get", "severity"],
              "critical", "#7e0023",
              "high", "#cc0033",
              "medium", "#ff9933",
              "low", "#ffde33",
              "#8a8a8a"
            ],
            "circle-opacity": 0.85,
            "circle-stroke-color": "#ffffff",
            "circle-stroke-width": 1
          }
        }
      ],
      "legend": {
        "kind": "categorical",
        "title": "Road conditions",
        "items": [
          { "color": "#7e0023", "label": "Critical" },
          { "color": "#cc0033", "label": "High" },
          { "color": "#ff9933", "label": "Medium" },
          { "color": "#ffde33", "label": "Low" }
        ]
      },
      "popup": {
        "titleField": "headline",
        "rows": [
          { "field": "type", "label": "Type" },
          { "field": "severity", "label": "Severity" },
          { "field": "description", "label": "Details" }
        ]
      }
    }
  },
  "backend": {
    "routes": true
  },
  "requires": [{ "service": "postgis" }, { "service": "openconditions-ingest" }],
  "healthCheck": {
    "type": "http",
    "url": "http://openconditions-ingest:4100/status"
  },
  "dataSources": [
    {
      "sourceId": "ndw",
      "name": "NDW (Netherlands)",
      "url": "https://www.ndw.nu",
      "license": "CC0-1.0",
      "attribution": "Data: © NDW / Rijkswaterstaat",
      "commercialUse": "yes",
      "providerCountry": "NL",
      "providerPrivacyUrl": "https://www.ndw.nu/privacy"
    }
  ]
}
