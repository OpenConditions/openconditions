{
  "name": "@openconditions/contributions-api",
  "version": "0.1.0",
  "description": "OpenConditions contributions service — crowd report intake and evidence-state recompute",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "private": true,
  "exports": {
    "./federation/ingest": {
      "types": "./dist/federation/ingest.d.ts",
      "import": "./dist/federation/ingest.js"
    },
    "./contrib": {
      "types": "./dist/contrib.d.ts",
      "import": "./dist/contrib.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@cloudflare/privacypass-ts": "0.9.0",
    "@openconditions/contrib-core": "workspace:*",
    "@openconditions/core": "workspace:*",
    "@openconditions/ingest": "workspace:*",
    "@openconditions/normalize": "workspace:*",
    "@openconditions/roads": "workspace:*",
    "fastify": "^5.0.0",
    "postgres": "^3.4.0",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@openconditions/publishers": "workspace:*",
    "@types/node": "^24.0.0",
    "testcontainers": "^12.0.3",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
