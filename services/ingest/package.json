{
  "name": "@openconditions/ingest",
  "version": "0.1.0",
  "description": "OpenConditions ingest service — fetch → parse → atomic PostGIS swap",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "private": true,
  "exports": {
    "./pipeline/normalize": {
      "types": "./dist/pipeline/normalize.d.ts",
      "import": "./dist/pipeline/normalize.js"
    },
    "./pipeline/write-postgis": {
      "types": "./dist/pipeline/write-postgis.d.ts",
      "import": "./dist/pipeline/write-postgis.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@openconditions/core": "workspace:*",
    "@openconditions/ingest-framework": "workspace:*",
    "@openconditions/openlr": "workspace:*",
    "@openconditions/publishers": "workspace:*",
    "@openconditions/roads": "workspace:*",
    "croner": "^10.0.1",
    "fastify": "^5.0.0",
    "postgres": "^3.4.0",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "gtfs-realtime-bindings": "^2.0.0",
    "hyparquet": "1.26.2",
    "testcontainers": "^12.0.3",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
