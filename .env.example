# OpenConditions ingest — environment configuration
#
# Copy to `.env` and fill in. Every road feed below is credential-gated: the
# scheduler skips a feed until all of its variables are set, so you only need the
# ones for the sources you want live. See docs/road-feed-credentials.md for how to
# obtain each key and any access conditions.

# --- Service ---------------------------------------------------------------

# PostgreSQL/PostGIS connection (REQUIRED — the service refuses to start without it)
DATABASE_URL=postgres://openconditions:openconditions@localhost:5432/openconditions

# HTTP server (optional; defaults shown)
PORT=4100
HOST=0.0.0.0

# Rate limiting (optional; defaults shown)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Number of proxy hops to trust for client IPs (optional; default 1)
TRUST_PROXY_HOPS=1

# OpenLR map-match resolver service URL (optional). If unset, observations that
# carry only OpenLR (no coordinates) are dropped rather than resolved.
OPENLR_RESOLVER_URL=

# Egress guard caps applied to every feed fetch (optional; defaults shown)
OPENCONDITIONS_MAX_FEED_BYTES=268435456
OPENCONDITIONS_FETCH_TIMEOUT_MS=60000
OPENCONDITIONS_MAX_REDIRECTS=5

# Static archive (nightly GeoParquet published-view snapshot). The build writes a
# dated `archive-YYYY-MM-DD.parquet` of the redistributable published view (see
# docs/archive.md). Local filesystem only — object-storage/S3 upload is operator
# infra, not wired here.
# Output directory (optional; default ./data/archive).
OPENCONDITIONS_ARCHIVE_DIR=
# Cron for the nightly build (optional; default "30 3 * * *"; set "off" to disable).
ARCHIVE_CRON=

# Layered feed delivery (optional). Feeds load at boot from baked-in defaults +
# an operator-mounted directory + an optional (default-off) remote bundle,
# merged by feed id with precedence mounted > remote > baked-in.
#
# Directory of mounted *.json5 feed override/add files (overrides baked-in by id,
# no rebuild). Unset = baked-in feeds only.
OPENCONDITIONS_FEEDS_DIR=
# URL of a remote feed bundle (e.g. the public road-conditions-atlas). Only used
# when remote-pull is enabled below.
OPENCONDITIONS_FEEDS_REMOTE_URL=
# "true" opts into remote-pull (default off). Descriptors are schema-validated
# and URL-guarded; a snapshot is vendored under the state dir
# (${OPENCONDITIONS_STATE_DIR:-/data}/feeds) so the instance survives the remote
# being down.
OPENCONDITIONS_FEEDS_REMOTE_ENABLED=

# === Feed credentials — generated by `pnpm gen:credentials`; do not edit below this line ===

# Buenos Aires road closures (cortes)
# BA transport API registration: https://api-transporte.buenosaires.gob.ar/registro
# CC-BY-2.5-AR (commercial OK).
AR_BA_CLIENT_ID=
AR_BA_CLIENT_SECRET=

# ASFINAG events (Austria)
# ASFINAG content portal: https://contentportal.asfinag.at/
# CC-BY-4.0 for the two open event packages (some ASFINAG packages are paid).
AT_ASFINAG_USERNAME=
AT_ASFINAG_PASSWORD=

# Live Traffic NSW (New South Wales)
# Register at Transport NSW Open Data: https://opendata.transport.nsw.gov.au/data/user/register
# CC-BY-4.0; attribution "Transport for NSW".
AU_NSW_LIVETRAFFIC_API_KEY=

# QLDTraffic (Queensland)
# QLDTraffic: https://www.qldtraffic.qld.gov.au/
# Optional — the bundled public key is shared + rate-limited (100 req/min). Set your own to avoid 429s.
AU_QLD_TRAFFIC_API_KEY=

# LVZ.NRW (Nordrhein-Westfalen) via Mobilithek
# Mobilithek registration: https://mobilithek.info/registration-request
# This ONE certificate authenticates every German region feed — set it once, then add each region's subscription id. (The NRW state network is published under 'LVZ.NRW', not 'Straßen.NRW'.)
MOBILITHEK_CERT=
MOBILITHEK_KEY=
DE_NW_VERKEHR_SUBSCRIPTION_ID=

# NRW municipalities (Düsseldorf, Köln, Kreis Unna) via Mobilithek
# Mobilithek registration: https://mobilithek.info/registration-request
# This ONE certificate authenticates every German region feed — set it once, then add each region's subscription id. (The NRW state network is published under 'LVZ.NRW', not 'Straßen.NRW'.)
DE_NW_MOBILITHEK_KOMMUNAL_SUBSCRIPTION_ID=

# NRW.Mobidrom bundled roadworks via Mobilithek
# Mobilithek registration: https://mobilithek.info/registration-request
# This ONE certificate authenticates every German region feed — set it once, then add each region's subscription id. (The NRW state network is published under 'LVZ.NRW', not 'Straßen.NRW'.)
DE_NW_MOBILITHEK_MOBIDROM_SUBSCRIPTION_ID=

# Bayern via Mobilithek
# Mobilithek registration: https://mobilithek.info/registration-request
# This ONE certificate authenticates every German region feed — set it once, then add each region's subscription id. (The NRW state network is published under 'LVZ.NRW', not 'Straßen.NRW'.)
DE_BY_MOBILITHEK_SUBSCRIPTION_ID=

# Baden-Württemberg via Mobilithek
# Mobilithek registration: https://mobilithek.info/registration-request
# This ONE certificate authenticates every German region feed — set it once, then add each region's subscription id. (The NRW state network is published under 'LVZ.NRW', not 'Straßen.NRW'.)
