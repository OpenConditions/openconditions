# OpenConditions ingest — environment configuration
#
# Copy to `.env` and fill in. Every road feed below is credential-gated: the
# scheduler skips a feed until all of its variables are set, so you only need the
# ones for the sources you want live. See docs/road-feed-credentials.md for how to
# obtain each key and any access conditions.

# --- Service ---------------------------------------------------------------

# PostgreSQL/PostGIS connection (REQUIRED — the service refuses to start without it)
DATABASE_URL=postgres://openconditions:openconditions@localhost:5432/openconditions

# HTTP server (optional; defaults shown)
PORT=4100
HOST=0.0.0.0

# Rate limiting (optional; defaults shown)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Number of proxy hops to trust for client IPs (optional; default 1)
TRUST_PROXY_HOPS=1

# OpenLR map-match resolver service URL (optional). If unset, observations that
# carry only OpenLR (no coordinates) are dropped rather than resolved.
OPENLR_RESOLVER_URL=

# --- Feed credentials ------------------------------------------------------
# Leave blank to keep a feed inactive. Fill all vars for a feed to activate it.

# Hrvatske ceste (Croatia) — B2B account from the promet-info operator
HC_HR_USERNAME=
HC_HR_PASSWORD=

# 511NY (USA) — free key from 511ny.org/developers (accept the Developer Access Agreement)
NY_511_API_KEY=

# LTA DataMall (Singapore) — AccountKey emailed after request at datamall.lta.gov.sg
LTA_ACCOUNT_KEY=

# Trafikverket (Sweden) — free key from api.trafikinfo.trafikverket.se (sent in the POST body)
TRAFIKVERKET_API_KEY=

# NAP Slovenia (promet.si) — account from nap.si. NOTE: CC-BY-SA (ShareAlike).
# Auth scaffolded as Basic; may be OAuth2 — verify when granted.
NAP_SI_USERNAME=
NAP_SI_PASSWORD=

# Statens vegvesen (Norway) — free account; Basic auth
NO_VEGVESEN_USERNAME=
NO_VEGVESEN_PASSWORD=

# Live Traffic NSW (Australia) — app key from opendata.transport.nsw.gov.au
NSW_TRANSPORT_API_KEY=

# QLDTraffic (Australia) — OPTIONAL. A public key is bundled as default; set this
# only to override it with your own key (email QLDTraffic@tmr.qld.gov.au) and
# avoid the shared, globally rate-limited public quota.
QLD_TRAFFIC_API_KEY=

# Buenos Aires road closures (Argentina) — client_id + client_secret from api-transporte.buenosaires.gob.ar
BA_CLIENT_ID=
BA_CLIENT_SECRET=

# National Highways NTIS (England) — subscription key from developer.data.nationalhighways.co.uk
NH_API_KEY=

# Vejdirektoratet (Denmark) — free key from nap.vd.dk
DK_VD_API_KEY=

# ASFINAG (Austria) — account from contentportal.asfinag.at (choose a free package); Basic auth
AT_ASFINAG_USERNAME=
AT_ASFINAG_PASSWORD=

# Tark Tee (Estonia) — key from tarktee.mnt.ee
EE_TARKTEE_API_KEY=

# Germany via Mobilithek — ONE organisation machine certificate (mTLS) authenticates
# every German region feed below. CERT/KEY hold the PEM contents of the client
# certificate and its private key (set up once; see docs/road-feed-credentials.md).
MOBILITHEK_NRW_CERT=
MOBILITHEK_NRW_KEY=

# Per-region Mobilithek subscription id(s) — comma-separate multiple, one per
# subscribed offer. Each feed stays dormant until its id(s) are set. Offer ids,
# publishers and licenses are catalogued in docs/road-feed-credentials.md.
MOBILITHEK_NRW_SUBSCRIPTION_ID=
MOBILITHEK_NRW_KOMMUNAL_SUBSCRIPTION_ID=
MOBILITHEK_NRW_MOBIDROM_SUBSCRIPTION_ID=
MOBILITHEK_BAYERN_SUBSCRIPTION_ID=
MOBILITHEK_BW_SUBSCRIPTION_ID=
MOBILITHEK_BERLIN_SUBSCRIPTION_ID=
MOBILITHEK_BRANDENBURG_SUBSCRIPTION_ID=
MOBILITHEK_BREMEN_SUBSCRIPTION_ID=
MOBILITHEK_HAMBURG_SUBSCRIPTION_ID=
MOBILITHEK_HESSEN_SUBSCRIPTION_ID=
MOBILITHEK_MV_SUBSCRIPTION_ID=
MOBILITHEK_NIEDERSACHSEN_SUBSCRIPTION_ID=
MOBILITHEK_SACHSEN_SUBSCRIPTION_ID=
MOBILITHEK_SACHSEN_ANHALT_SUBSCRIPTION_ID=
MOBILITHEK_SH_SUBSCRIPTION_ID=
MOBILITHEK_THUERINGEN_SUBSCRIPTION_ID=
