MOBILITHEK_KEY=
MOBILITHEK_NRW_KOMMUNAL_SUBSCRIPTION_ID=

# NRW.Mobidrom bundled roadworks via Mobilithek
# Mobilithek registration: https://mobilithek.info/registration-request
