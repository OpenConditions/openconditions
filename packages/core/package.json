{
  "name": "@openconditions/core",
  "version": "0.1.0",
  "description": "Generic two-axis canonical model, severity, and freshness helpers for OpenConditions",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "drizzle-kit": "^0.31.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  }
}
