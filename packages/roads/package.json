{
  "name": "@openconditions/roads",
  "version": "0.1.0",
  "description": "RoadEvent model, DATEX II SituationPublication parser, and taxonomy for OpenConditions roads domain",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "feeds"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "export:atlas": "node scripts/export-atlas.ts",
    "feeds:lint": "pnpm --filter @openconditions/ingest-framework build && pnpm --filter @openconditions/roads build && tsx scripts/feeds-lint.ts"
  },
  "dependencies": {
    "@openconditions/core": "workspace:*",
    "@openconditions/ingest-framework": "workspace:*",
    "fast-xml-parser": "^5.8.0",
    "proj4": "^2.20.9",
    "saxes": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/proj4": "^2.19.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
