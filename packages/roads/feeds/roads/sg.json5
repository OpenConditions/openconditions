[
  {
    operator: "lta",
    name: "LTA DataMall Traffic Incidents (Singapore)",
    format: "lta",
    url: "https://datamall2.mytransport.sg/ltaodataservice/TrafficIncidents",
    auth: {
      kind: "header-key",
      header: "AccountKey",
      envVar: "SG_LTA_ACCOUNT_KEY",
    },
    cadenceSec: 120,
    freshnessWindowSec: 600,
    license: "Singapore-ODL-1.0",
    licenseUrl: "https://datamall.lta.gov.sg/content/datamall/en/SingaporeOpenDataLicence.html",
    attribution: "Land Transport Authority (Singapore)",
    country: "SG",
    privacyUrl: "https://www.lta.gov.sg/content/ltagov/en/privacy.html",
    setup: {
      SG_LTA_ACCOUNT_KEY: {
        title: "LTA DataMall AccountKey (Singapore)",
        url: "https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html",
        urlLabel: "Request LTA API access",
        steps: [
          "Request an API account via the form at datamall.lta.gov.sg/content/datamall/en/request-for-api.html.",
          "The AccountKey is emailed to you.",
        ],
        cost: "Free",
        notes: "Singapore ODL (commercial OK); attribution to the Land Transport Authority.",
      },
    },
  },
  {
    operator: "lta",
    stream: "speedbands",
    name: "LTA DataMall Traffic Speed Bands (Singapore)",
    format: "lta-speedbands",
    produces: "flow",
    url: "https://datamall2.mytransport.sg/ltaodataservice/v3/TrafficSpeedBands",
    auth: {
      kind: "header-key",
      header: "AccountKey",
      envVar: "SG_LTA_ACCOUNT_KEY",
    },
    // DataMall caps this resource at 500 links per call; the fetch layer follows
    // $skip (pagination below) to pull every page, so coverage is complete rather
    // than first-page-only. Reuses the shared SG_LTA_ACCOUNT_KEY (see lta-sg
    // above), so it runs whenever that key is set.
    // maxPages well above the dataset size (TrafficSpeedBands runs ~4k-58k links
    // = up to ~116 pages) so a large cycle is never truncated and its rows pruned.
    pagination: { skipParam: "$skip", pageSize: 500, maxPages: 200 },
    cadenceSec: 300,
    freshnessWindowSec: 900,
    license: "Singapore-ODL-1.0",
    licenseUrl: "https://datamall.lta.gov.sg/content/datamall/en/SingaporeOpenDataLicence.html",
    attribution: "Land Transport Authority (Singapore)",
    country: "SG",
    privacyUrl: "https://www.lta.gov.sg/content/ltagov/en/privacy.html",
    setup: {
      SG_LTA_ACCOUNT_KEY: {
        title: "LTA DataMall AccountKey (Singapore)",
        url: "https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html",
        urlLabel: "Request LTA API access",
        steps: [
          "Request an API account via the form at datamall.lta.gov.sg/content/datamall/en/request-for-api.html.",
          "The AccountKey is emailed to you.",
        ],
        cost: "Free",
        notes: "Singapore ODL (commercial OK); attribution to the Land Transport Authority. Shared with the LTA Traffic Incidents feed.",
      },
    },
  },
]
