  {
    "name": "QLDTraffic (Queensland)",
    "format": "geojson",
    "operator": "traffic",
    "subdivision": "qld",
    "url": "https://api.qldtraffic.qld.gov.au/v1/events",
    "auth": {
      "kind": "query-key",
      "param": "apikey",
      "envVar": "AU_QLD_TRAFFIC_API_KEY",
      "defaultValue": "3e83add325cbb69ac4d8e5bf433d770b"
    },
    "cadenceSec": 300,
    "freshnessWindowSec": 900,
    "license": "CC-BY-4.0",
    "licenseUrl": "https://www.qldtraffic.qld.gov.au/",
    "attribution": "State of Queensland (Department of Transport and Main Roads)",
    "country": "AU",
    "privacyUrl": "https://www.qld.gov.au/legal/privacy",
    "setup": {
      "AU_QLD_TRAFFIC_API_KEY": {
        "url": "https://www.qldtraffic.qld.gov.au/",
        "urlLabel": "QLDTraffic",
        "notes": "Optional — the bundled public key is shared + rate-limited (100 req/min). Set your own to avoid 429s.",
        "email": {
          "to": "QLDTraffic@tmr.qld.gov.au",
          "subject": "QLDTraffic API key request",
          "body": "Organisation name, contact person, email, and application name."
        },
        "title": "QLDTraffic API key (Australia) — optional",
        "description": "Optional. A public key is bundled by default; set this only to use your own quota."
      }
    },
    "enabledByDefault": true,
    "geojson": {
      "idField": "id",
      "typeField": "event_type",
      "typeMap": {
        "Hazard": "hazard",
        "Crash": "accident",
        "Congestion": "congestion",
        "Roadworks": "roadworks",
        "Special event": "public_event",
        "Flooding": "weather"
      },
      "defaultType": "other",
      "headlineField": "description",
      "descriptionField": "information",
      "severityField": "event_priority",
      "severityMap": {
        "Red Alert": "critical",
        "High": "high",
        "Medium": "medium",
        "Low": "low"
      },
      "roadField": "road_summary.road_name",
      "updatedField": "last_updated"
    },
    "id": "au-qld-traffic"
  },
