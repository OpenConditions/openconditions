[
  {
    "name": "Buenos Aires road closures (cortes)",
    "format": "geojson",
    "operator": "cortes",
    "subdivision": "ba",
    "url": "https://apitransporte.buenosaires.gob.ar/transito/v1/cortes?client_id=${AR_BA_CLIENT_ID}&client_secret=${AR_BA_CLIENT_SECRET}",
    "requiredEnv": [
      "AR_BA_CLIENT_ID",
      "AR_BA_CLIENT_SECRET"
    ],
    "cadenceSec": 300,
    "freshnessWindowSec": 900,
    "license": "CC-BY-2.5-AR",
    "licenseUrl": "https://data.buenosaires.gob.ar/",
    "attribution": "Gobierno de la Ciudad de Buenos Aires",
    "country": "AR",
    "privacyUrl": "https://www.buenosaires.gob.ar/politicas-de-privacidad",
    "setup": {
      "AR_BA_CLIENT_ID": {
        "url": "https://api-transporte.buenosaires.gob.ar/registro",
        "urlLabel": "BA transport API registration",
        "steps": [
          "Register / request a key at api-transporte.buenosaires.gob.ar/registro. The client_id + client_secret pair is sent to you by email."
        ],
        "notes": "CC-BY-2.5-AR (commercial OK).",
        "title": "Buenos Aires transport — client_id"
      },
      "AR_BA_CLIENT_SECRET": {
        "title": "Buenos Aires transport — client_secret"
      }
    },
    "enabledByDefault": true,
    "geojson": {
      "defaultType": "road_closure",
      "headlineField": "nombre",
      "descriptionField": "descripcion"
    },
    "id": "ar-ba-cortes"
  },
  {
