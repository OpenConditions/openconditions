    },
    "cadenceSec": 300,
    "freshnessWindowSec": 900,
    "license": "CC0-1.0",
    "licenseUrl": "https://data.trafikverket.se/",
    "attribution": "Trafikverket",
    "country": "SE",
    "privacyUrl": "https://www.trafikverket.se/integritetspolicy/",
    "setup": {
      "SE_TRAFIKVERKET_API_KEY": {
        "url": "https://data.trafikverket.se/oauth2/Account/register",
        "urlLabel": "Sign up at Trafikverket",
        "steps": [
          "Sign up at data.trafikverket.se/oauth2/Account/register.",
          "Create an authentication key under data.trafikverket.se/mypage/systems (My systems). The key is sent in the POST request body."
        ],
        "cost": "Free",
        "notes": "CC0 — no restrictions. API endpoint: api.trafikinfo.trafikverket.se/v2/data.json (the bare host has no web page).",
        "title": "Trafikverket key (Sweden)",
        "description": "Authentication key, sent in the POST request body."
      }
    },
    "enabledByDefault": true,
    "posListLonLat": true,
    "id": "se-trafikverket"
  },
  {
    "name": "Trafikverket traffic flow (Sweden)",
    "format": "trafikverket-flow",
    "operator": "trafikverket",
    "stream": "flow",
    "produces": "flow",
    "url": "https://api.trafikinfo.trafikverket.se/v2/data.json",
    "method": "POST",
    "bodyTemplate": "<REQUEST><LOGIN authenticationkey=\"${SE_TRAFIKVERKET_API_KEY}\"/><QUERY objecttype=\"TrafficFlow\" schemaversion=\"1.4\"><INCLUDE>SiteId</INCLUDE><INCLUDE>AverageVehicleSpeed</INCLUDE><INCLUDE>VehicleFlowRate</INCLUDE><INCLUDE>MeasurementTime</INCLUDE><INCLUDE>Geometry.WGS84</INCLUDE></QUERY></REQUEST>",
    "requestHeaders": {
      "Content-Type": "text/xml"
    },
    "requiredEnv": [
      "SE_TRAFIKVERKET_API_KEY"
    ],
    "cadenceSec": 300,
    "freshnessWindowSec": 900,
    "license": "CC0-1.0",
    "licenseUrl": "https://api.trafikinfo.trafikverket.se/",
    "attribution": "Trafikverket",
    "country": "SE",
    "privacyUrl": "https://www.trafikverket.se/en/privacy-policy/",
    "setup": {
      "SE_TRAFIKVERKET_API_KEY": {
        "url": "https://data.trafikverket.se/oauth2/Account/register",
        "urlLabel": "Sign up at Trafikverket",
        "steps": [
          "Sign up at data.trafikverket.se/oauth2/Account/register.",
          "Create an authentication key under data.trafikverket.se/mypage/systems (My systems). The key is sent in the POST request body."
        ],
        "cost": "Free",
        "notes": "CC0 — no restrictions. API endpoint: api.trafikinfo.trafikverket.se/v2/data.json (the bare host has no web page).",
        "title": "Trafikverket key (Sweden)",
        "description": "Authentication key, sent in the POST request body."
      }
    },
    "enabledByDefault": true,
    "id": "se-trafikverket-flow"
  },
