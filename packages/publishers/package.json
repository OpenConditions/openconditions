{
  "name": "@openconditions/publishers",
  "version": "0.1.0",
  "description": "Outbound emitters (GeoJSON, TraFF, JSON-LD) — pure projections from the OpenConditions canonical model to standard wire formats",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@openconditions/core": "workspace:*",
    "@openconditions/ingest-framework": "workspace:*",
    "fast-xml-parser": "^5.8.0",
    "gtfs-realtime-bindings": "^2.0.0"
  },
  "devDependencies": {
    "@openconditions/roads": "workspace:*",
    "@types/geojson": "^7946.0.14",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
