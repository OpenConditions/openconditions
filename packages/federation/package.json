{
  "name": "@openconditions/federation",
  "version": "0.1.0",
  "description": "Federated instance identity for OpenConditions — Ed25519 instance keys, the Actor document, and the bilateral-pin peers registry",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@openconditions/core": "workspace:*",
    "testcontainers": "^12.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
