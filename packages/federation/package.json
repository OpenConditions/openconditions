{
  "name": "@openconditions/federation",
  "version": "0.1.0",
  "description": "Federated instance identity for OpenConditions — Ed25519 instance keys, the Actor document, and the bilateral-pin peers registry",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@openconditions/core": "workspace:*",
    "@openconditions/ingest-framework": "workspace:*",
    "@openconditions/publishers": "workspace:*",
    "@tufjs/canonical-json": "2.0.0",
    "@tufjs/models": "5.0.0",
    "http-message-signatures": "1.0.6",
    "postgres": "^3.4.0",
    "structured-headers": "^2.0.2",
    "tuf-js": "6.0.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "testcontainers": "^12.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
